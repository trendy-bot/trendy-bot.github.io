---
import '@pagefind/default-ui/css/ui.css'
import '../../../../src/assets/styles/pagefind.css'
---

<!-- 
  修改点：
  1. 恢复 max-h-[33.33vh]: 这是你原始设定的高度。
  2. 保持 top-[15vh]: 确保上边沿固定，不会被结果顶上去。
  3. left-1/2 -translate-x-1/2 m-0: 居中并清除默认 margin。
-->
<dialog
  id='search-modal'
  class='fixed top-[10vh] left-1/2 -translate-x-1/2 m-0
         bg-background/95 border border-border/60 rounded-2xl
         w-[90vw] max-w-2xl max-h-[70vh]
         overflow-hidden p-5
         shadow-[0_25px_50px_-12px_rgba(0,0,0,0.25),0_0_0_1px_rgba(255,255,255,0.05)_inset]
         backdrop-blur-xl'
>
  <site-search>
    {
      import.meta.env.DEV ? (
        <div class='w-full rounded-xl border-2 bg-transparent px-4 py-2 pe-3 outline-none focus:border-foreground'>
          You are in Dev mode, the search is disabled.
        </div>
      ) : (
        <div id='site-search' />
      )
    }
  </site-search>
</dialog>

<script>
  class SiteSearch extends HTMLElement {
    constructor() {
      super()
      const formatURL = (path: string) => path.replace(/(.)\/(#.*)?$/, '$1$2')

      window.addEventListener('DOMContentLoaded', () => {
        const onIdle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1))
        onIdle(async () => {
          // @ts-expect-error — Missing types for @pagefind/default-ui package.
          const { PagefindUI } = await import('@pagefind/default-ui')
          new PagefindUI({
            element: '#site-search',
            baseUrl: import.meta.env.BASE_URL,
            bundlePath: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/pagefind/`,
            showImages: false,
            showSubResults: true,
            autofocus: true,
            processResult: (result: { url: string; sub_results: Array<{ url: string }> }) => {
              result.url = formatURL(result.url)
              result.sub_results = result.sub_results.map((sub_result) => {
                sub_result.url = formatURL(sub_result.url)
                return sub_result
              })
            }
          })
        })
      })
    }
  }
  customElements.define('site-search', SiteSearch)

  const modal = document.getElementById('search-modal') as HTMLDialogElement | null
  const openBtn = document.getElementById('open-search-modal')

  const getScrollbarWidth = () => {
    return window.innerWidth - document.documentElement.clientWidth
  }

  const openModal = () => {
    const scrollbarWidth = getScrollbarWidth()
    if (scrollbarWidth > 0) {
      document.body.style.paddingRight = `${scrollbarWidth}px`
    }
    document.body.style.overflow = 'hidden'
    modal?.showModal()
  }

  const closeModalWithAnimation = () => {
    if (!modal) return
    modal.classList.add('closing')
    setTimeout(() => {
      modal.classList.remove('closing')
      modal.close()
      document.body.style.overflow = ''
      document.body.style.paddingRight = ''
    }, 200)
  }

  openBtn?.addEventListener('click', openModal)

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModalWithAnimation()
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.open) {
      e.preventDefault()
      closeModalWithAnimation()
    }
  })
</script>

<style is:global>
  #site-search {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: hsl(var(--primary) / var(--un-bg-opacity, 1));
    --pagefind-ui-text: hsl(var(--foreground) / var(--un-text-opacity, 1));
    --pagefind-ui-background: hsl(var(--muted) / var(--un-bg-opacity, 1));
    --pagefind-ui-border: hsl(var(--border) / var(--un-border-opacity, 1));
    --pagefind-ui-tag: hsl(var(--muted-foreground) / var(--un-text-opacity, 1));
    --pagefind-ui-border-width: 1.5px;
    --pagefind-ui-border-radius: calc(var(--radius) + 4px);
    --pagefind-ui-image-border-radius: calc(var(--radius) + 4px);
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: system-ui, -apple-system, sans-serif;
  }

  /* 遮罩层动画 */
  dialog::backdrop {
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0.6) 100%);
    backdrop-filter: blur(8px);
    animation: backdrop-in 0.3s ease-out;
  }

  dialog.closing::backdrop {
    animation: backdrop-out 0.25s ease-in forwards;
  }

  @keyframes backdrop-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes backdrop-out {
    from { opacity: 1; }
    to { opacity: 0; }
  }

  /* 进场动画：从上方优雅弹出 */
  dialog[open] {
    animation: modal-in 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* 出场动画：向上淡出 */
  dialog.closing {
    animation: modal-out 0.25s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes modal-in {
    from {
      opacity: 0;
      transform: translate(-50%, -20px) scale(0.96);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translate(-50%, 0) scale(1);
      filter: blur(0);
    }
  }

  @keyframes modal-out {
    from {
      opacity: 1;
      transform: translate(-50%, 0) scale(1);
      filter: blur(0);
    }
    to {
      opacity: 0;
      transform: translate(-50%, -16px) scale(0.98);
      filter: blur(4px);
    }
  }
</style>